{
  "version": "m7_v2_parameter_config@v1.0.0",
  "updated_at": "2026-04-27",
  "scope": "M7 v2 sandbox parameter governance",
  "status": "sandbox",
  "owner": "MM control center",
  "do_not_touch": [
    "production M7 engine",
    "M8 engine",
    "M3 engine"
  ],
  "m7_v2_weights": {
    "valuation": 0.45,
    "trend": 0.25,
    "structure": 0.2,
    "timing": 0,
    "money": 0.1
