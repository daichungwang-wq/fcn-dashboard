    "risk_off_bear": { "multiplier": 0.9, "note": "de-rate valuation under macro stress" },
    "normal": { "multiplier": 1.0, "note": "neutral baseline" },
    "growth_bull": { "multiplier": 1.12, "note": "moderate premium in growth-led tape" },
